class Solution {
    public int minSubArrayLen(int target, int[] a) {
        int sum=0,j=0,res=Integer.MAX_VALUE;
        for (int i=0;i<a.length;i++){
            sum = sum +a[i];
            while (sum>=target) {
                res = Math.min(res, i-j+1);
                sum=sum-a[j];
                j++;
            }
        }
        if (res==Integer.MAX_VALUE) return 0;
        return res;
    }
}
